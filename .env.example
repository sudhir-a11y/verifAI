AWS_TEXTRACT_REGION=ap-south-1
AWS_TEXTRACT_ACCESS_KEY_ID=
AWS_TEXTRACT_SECRET_ACCESS_KEY=
AWS_TEXTRACT_SESSION_TOKEN=
AWS_TEXTRACT_ENDPOINT_URL=

# 🎯 Phase 0: Hybrid OCR Configuration (PaddleOCR + OpenAI + Textract + Tesseract)
# Hybrid OCR enables local, offline-capable OCR with intelligent provider routing
# Leave blank to disable hybrid OCR (system will use cloud providers as fallback)

# OpenAI model for handwriting interpretation (prescriptions)
# Recommended: GPT-5.1
OPENAI_VISION_MODEL=gpt-5.1

# PaddleOCR Model Version (v3 recommended for latest improvements)
# v2: Previous version (faster but less accurate)
# v3: Latest version (more accurate, slower on first run)
PADDLE_MODEL_TYPE=v3

# Tesseract fallback OCR (system command path)
# Linux: /usr/bin/tesseract (install with: apt-get install tesseract-ocr)
# macOS: /usr/local/bin/tesseract (install with: brew install tesseract)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Leave blank to use system PATH
TESSERACT_CMD_PATH=

# OCR Confidence Threshold (0.0 - 1.0)
# Results below this score will trigger fallback to alternate provider
OCR_CONFIDENCE_THRESHOLD=0.6

# Maximum PDF Pages to Process
# Limits pages extracted to prevent timeout on large PDFs
OCR_PAGE_LIMIT=50

# ⚠️ IMPORTANT: Phase 0 Setup Checklist
# Before running tests or using hybrid OCR:
#
# 1. Install Tesseract (optional but recommended for fallback):
#    Linux:   sudo apt-get install -y tesseract-ocr
#    macOS:   brew install tesseract
#    Windows: Download from https://github.com/UB-Mannheim/tesseract/wiki
#
#    Then set TESSERACT_CMD_PATH to your tesseract binary path.
#    Leave blank to use system PATH (if installed globally).
#
# 2. Configure OpenAI API Key (recommended for prescription/handwriting OCR):
#    - Already configured via OPENAI_API_KEY above
#    - Set OPENAI_VISION_MODEL=gpt-5.1 (or your preferred model)
#    - First PaddleOCR run will download ~200MB model (one-time, 30-60s)
#
# 3. Configure AWS Textract (optional, for structured documents):
#    - Set AWS_TEXTRACT_REGION, AWS_TEXTRACT_ACCESS_KEY_ID, AWS_TEXTRACT_SECRET_ACCESS_KEY
#    - Or use IAM roles if running on AWS
#
# 4. Run Phase 0 tests:
#    cd backend && .venv/bin/pytest tests/ -v
#
# Verification Commands:
#    tesseract --version                    # Verify Tesseract
#    python -c "import paddleocr; print('PaddleOK')"  # Verify PaddleOCR
#    python -c "import pytesseract; print('TesseractOK')"  # Verify pytesseract

RAZORPAY_IFSC_VERIFY_ENABLED=true
RAZORPAY_IFSC_API_BASE_URL=https://ifsc.razorpay.com
RAZORPAY_IFSC_TIMEOUT_SECONDS=8
